  m_Script: {fileID: 11500000, guid: b7c871f8520f3fc4ba9465f53662a56f, type: 3}
  m_Name: Start
  m_EditorClassIdentifier: Assembly-CSharp::NPCData
  displayName: The Boss
  lines:
  - Hey, this is your boss.
  - Sorry I couldn't meet you in person today, something came up.
  - Anyways, I hired you to keep watch over the graveyard.
  - We've been having some complaints about "paranormal activity".
  - I don't buy it though, but I guess you should report that stuff to me if it happens.
  - Your training was yesterday, so just do as I taught you and patrol the site.
    Don't mess anything up.
  - Call me if you need anything. Good luck!
  dialogueChoices: []
